<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background: a subtle warm radial glow behind the sun mark,
     instead of a flat near-black fill. Ties the icon to the app's own "dawn"
     visual identity (used on the Briefs page) rather than an arbitrary dark
     color — a minor tweak, not a redesign; still fundamentally dark/near-black
     at the edges so it reads the same at a glance. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="40"
                android:gradientRadius="82"
                android:startColor="#241209"
                android:centerColor="#140d0a"
                android:endColor="#0A0A0A" />
        </aapt:attr>
    </path>
</vector>
